.container{min-height:100vh;padding:40rpx 30rpx}.form{background:hsla(0,0%,100%,.05);border-radius:20rpx;padding:40rpx}.form-item{margin-bottom:40rpx}.label{color:hsla(0,0%,100%,.8);display:block;font-size:28rpx;margin-bottom:16rpx}.input{background:hsla(0,0%,100%,.1);border-radius:10rpx;box-sizing:border-box;color:#fff;font-size:28rpx;height:80rpx;padding:0 20rpx;width:100%}.picker{background:hsla(0,0%,100%,.1);border-radius:10rpx;color:#fff;font-size:28rpx;height:80rpx;line-height:80rpx;padding:0 20rpx}.save-btn{background:linear-gradient(135deg,#00f5ff,#b450ff);border:none;border-radius:45rpx;color:#fff;font-size:32rpx;height:90rpx;margin-top:40rpx;width:100%}.hint{color:hsla(0,0%,100%,.4);display:block;font-size:24rpx;margin-top:30rpx;text-align:center}