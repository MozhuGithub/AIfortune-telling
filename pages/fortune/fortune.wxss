.container{min-height:100vh;padding:30rpx}.empty-text{color:hsla(0,0%,100%,.5);display:block;font-size:28rpx;margin-top:200rpx;text-align:center}.header{margin-bottom:40rpx;text-align:center}.title{color:gold;font-size:40rpx;font-weight:700}.section{margin-bottom:40rpx}.section-title{color:#00f5ff;display:block;font-size:32rpx;margin-bottom:20rpx}.card{background:hsla(0,0%,100%,.08);border:1rpx solid rgba(255,215,0,.2);border-radius:16rpx;padding:30rpx}.level{color:gold;display:block;font-size:28rpx;margin-bottom:16rpx}.content{color:hsla(0,0%,100%,.8);display:block;font-size:26rpx;line-height:1.8}.details{color:hsla(0,0%,100%,.6);display:block;font-size:24rpx;line-height:1.6;margin-top:20rpx}.card-name{color:#b450ff;display:block;font-size:30rpx;font-weight:700;margin-bottom:16rpx}.meaning{color:hsla(0,0%,100%,.8);display:block;font-size:26rpx;line-height:1.8}