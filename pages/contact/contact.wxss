.container{min-height:100vh;padding:40rpx 30rpx}.card{background:hsla(0,0%,100%,.05);border-radius:20rpx;margin-bottom:40rpx;padding:40rpx}.title{color:gold;display:block;font-size:36rpx;margin-bottom:40rpx;text-align:center}.info-item{margin-bottom:30rpx}.label{color:hsla(0,0%,100%,.5);display:block;font-size:24rpx;margin-bottom:10rpx}.value-row{align-items:center;display:flex;justify-content:space-between}.value{color:#00f5ff;font-size:28rpx}.copy-btn{background:rgba(0,245,255,.2);border:none;color:#00f5ff}.tips{background:hsla(0,100%,71%,.1);border:1rpx solid hsla(0,100%,71%,.3);border-radius:16rpx;padding:30rpx}.tips-title{color:#ff6b6b;display:block;font-size:28rpx;margin-bottom:16rpx}.tips-content{color:hsla(0,0%,100%,.6);display:block;font-size:24rpx;line-height:1.8}