.container{align-items:center;display:flex;flex-direction:column;min-height:100vh;padding:40rpx 30rpx}.header{align-items:center;display:flex;height:300rpx;justify-content:center;margin-bottom:40rpx;position:relative;width:300rpx}.outer-ring{border:3rpx solid rgba(0,245,255,.6);border-radius:50%;box-shadow:0 0 20rpx rgba(0,245,255,.4);height:280rpx;position:absolute;width:280rpx}.middle-ring{border:2rpx solid rgba(180,80,255,.5);border-radius:50%;height:240rpx;position:absolute;width:240rpx}.inner-circle{align-items:center;background:radial-gradient(circle,#2a1a4a 0,#0a0a1a 100%);border:2rpx solid rgba(255,215,0,.8);border-radius:50%;box-shadow:0 0 30rpx rgba(138,43,226,.4);display:flex;height:180rpx;justify-content:center;width:180rpx}.bagua{color:gold;font-size:80rpx;text-shadow:0 0 20rpx rgba(255,215,0,.8)}.title-section{margin-bottom:60rpx;text-align:center}.title{background:linear-gradient(90deg,#00f5ff,#ff6bcb,gold);-webkit-background-clip:text;display:block;font-size:48rpx;font-weight:700;-webkit-text-fill-color:transparent;margin-bottom:20rpx}.subtitle{color:hsla(0,0%,100%,.7);display:block;font-size:28rpx;letter-spacing:4rpx}.action-section{text-align:center;width:100%}.draw-btn{background:linear-gradient(135deg,#00f5ff,#b450ff);border:none;border-radius:50rpx;box-shadow:0 10rpx 40rpx rgba(0,245,255,.4);height:100rpx;width:400rpx}.draw-btn .btn-text{color:#fff;font-size:36rpx;font-weight:700}.hint{color:hsla(0,0%,100%,.5);display:block;font-size:24rpx;margin-top:30rpx}.result-section{text-align:center;width:100%}.result-card{background:hsla(0,0%,100%,.1);border:1rpx solid rgba(255,215,0,.3);border-radius:20rpx;margin-bottom:30rpx;padding:40rpx}.result-title{color:gold;display:block;font-size:32rpx;margin-bottom:20rpx}.fortune-level{color:#00f5ff;display:block;font-size:48rpx;font-weight:700;margin-bottom:20rpx}.fortune-summary{color:hsla(0,0%,100%,.8);display:block;font-size:28rpx;line-height:1.6}.detail-btn{background:transparent;border:2rpx solid #00f5ff;border-radius:40rpx;color:#00f5ff;font-size:28rpx;height:80rpx;width:300rpx}.footer{bottom:40rpx;position:fixed;text-align:center}.footer-text{color:hsla(0,0%,100%,.3);font-size:22rpx}